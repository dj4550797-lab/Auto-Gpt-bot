import logging
import logging.config
import asyncio
from flask import Flask, request
from telegram import Update
from telegram.ext import Application, ContextTypes

import info
from database import db_client

# Import Handlers
from plugins.start import start_handler, callback_handler
from plugins.auth import auth_handler
from plugins.ai_chat import chat_handler
from plugins.premium import premium_cb_handler, premium_cmd_handler, payment_conv_handler
from plugins.admin import admin_handlers

# Setup logging from config file
logging.config.fileConfig('logging.conf', disable_existing_loggers=False)
logger = logging.getLogger(__name__)

# Initialize PTB Application
ptb_app = Application.builder().token(info.BOT_TOKEN).build()

# Add Handlers
# ... (imports)

# Import Handlers
# ... (other plugin imports)
from plugins.premium import (
    premium_cb_handler, 
    proceed_payment_cb_handler, 
    back_to_start_cb_handler, 
    premium_cmd_handler, 
    payment_conv_handler
)

# ... (ptb_app setup)

# Add Handlers
ptb_app.add_handler(start_handler)
ptb_app.add_handler(callback_handler)
ptb_app.add_handler(auth_handler)

# --- ADD THESE NEW PREMIUM HANDLERS ---
ptb_app.add_handler(premium_cb_handler)
ptb_app.add_handler(proceed_payment_cb_handler)
ptb_app.add_handler(back_to_start_cb_handler)
ptb_app.add_handler(premium_cmd_handler)
ptb_app.add_handler(payment_conv_handler)
# --- END OF ADDITIONS ---

for h in admin_handlers:
    ptb_app.add_handler(h)
ptb_app.add_handler(chat_handler)

# ... (rest of the file)
# Global Error Handler
async def error_handler(update: object, context: ContextTypes.DEFAULT_TYPE) -> None:
    logger.error("Exception while handling an update:", exc_info=context.error)
ptb_app.add_error_handler(error_handler)

# Auto Cleanup Job
async def auto_cleanup(context: ContextTypes.DEFAULT_TYPE):
    import time
    now = time.time()
    users = db_client.get_all_users()
    for u in users:
        # Expire Premium
        if u.get("is_premium") and u.get("premium_expiry") and now > u.get("premium_expiry"):
            db_client.update_user(u["user_id"], {"is_premium": False, "premium_expiry": None})
            try:
                await context.bot.send_message(u["user_id"], "⚠️ Your Premium subscription has expired. Use /upgrade to renew!")
            except Exception as e:
                logger.warning(f"Could not notify user {u['user_id']} of premium expiry: {e}")

ptb_app.job_queue.run_repeating(auto_cleanup, interval=3600, first=10)

# Flask App for Webhook
flask_app = Flask(__name__)

@flask_app.route('/')
def index():
    return "FLIXORA AI Bot is running."

@flask_app.route(f'/{info.BOT_TOKEN}', methods=['POST'])
def webhook():
    try:
        update = Update.de_json(request.get_json(force=True), ptb_app.bot)
        loop = asyncio.new_event_loop()
        asyncio.set_event_loop(loop)
        loop.run_until_complete(ptb_app.process_update(update))
        loop.close()
        return "OK", 200
    except Exception as e:
        logger.error(f"Webhook error: {e}")
        return "Error", 500

async def setup():
    await ptb_app.initialize()
    if info.WEBHOOK_URL:
        webhook_url = f"{info.WEBHOOK_URL}/{info.BOT_TOKEN}"
        await ptb_app.bot.set_webhook(url=webhook_url)
        logger.info(f"Webhook set to {webhook_url}")
    else:
        logger.info("Starting bot in polling mode (no WEBHOOK_URL set)")
        await ptb_app.updater.start_polling()
        await ptb_app.start()

if __name__ == '__main__':
    loop = asyncio.get_event_loop()
    loop.run_until_complete(setup())
    
    if not info.WEBHOOK_URL:
        # This part only runs if you're not using a webhook (for local testing)
        loop.run_forever()
    else:
        logger.info("Flask server will handle updates via webhook.")
        # When deployed, Gunicorn will run flask_app.
        # For local webhook testing, you can run this script directly.
        flask_app.run(host="0.0.0.0", port=info.PORT)